<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <!-- Keep restored packages in the local packages/ folder (consistent with the existing layout). -->
    <add key="globalPackagesFolder" value="packages" />
  </config>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
